{
  "name": "waterfall-autopsy",
  "version": "0.1.0",
  "description": "Drop in a .har network export and get an opinionated autopsy report of what's costing you load time.",
  "type": "module",
  "license": "MIT",
  "author": "Charlie Krug",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ctkrug/waterfall-autopsy.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "chart.js": "^4.4.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
